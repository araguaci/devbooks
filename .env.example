# DevBooks - Variáveis de ambiente para Docker
# Copie para .env e preencha os valores

# Obrigatório - Chave para tokens JWT
JWT_SECRET=altere-para-um-segredo-forte

# Opcional - Login com Google (Google Cloud Console)
# Use o mesmo valor em ambos (backend verifica token, frontend exibe botão)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com

# Opcional - Base para links de PDF (ex: GitHub raw)
GITHUB_RAW_BASE=https://raw.githubusercontent.com/USER/REPO/main

# Opcional - Turso (se usar em vez de SQLite local)
# TURSO_DATABASE_URL=libsql://devbooks-xxx.turso.io
# TURSO_AUTH_TOKEN=eyJ...
