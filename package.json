{
  "name": "devbooks",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "cd client && npm ci && npm run build",
    "dev": "concurrently -n server,client -c cyan,orange \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cd server && npm run dev",
    "dev:client": "cd client && npm run dev",
    "deploy": "netlify deploy --prod",
    "deploy:vercel": "vercel --prod",
    "seed": "cd server && npm run seed"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@libsql/client": "^0.14.0",
    "serverless-http": "^3.2.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.2"
  }
}
